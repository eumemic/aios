# aios server configuration. Copy to .env and edit.

# Required: shared API key clients send as `Authorization: Bearer <key>`.
# Generate with: openssl rand -hex 32
AIOS_API_KEY=replace-me

# Required: 32 random bytes, base64-encoded, used to encrypt credentials at rest.
# Generate with: openssl rand -base64 32
AIOS_VAULT_KEY=replace-me

# Required: Postgres connection URL.
AIOS_DB_URL=postgresql://aios:aios@localhost:5432/aios

# Sandbox image used for all v1 sessions. Built from docker/Dockerfile.sandbox.
AIOS_DOCKER_IMAGE=aios-sandbox:latest

# Where per-session workspace directories live on the host.
# Each session gets a subdir at $AIOS_WORKSPACE_ROOT/<session_id>/, mounted into
# the container at /workspace.
AIOS_WORKSPACE_ROOT=/var/lib/aios/workspaces

# Maximum number of concurrent Docker containers the sandbox pool will create.
AIOS_POOL_SIZE_MAX=16

# Worker concurrency: how many session loops a single worker process runs in parallel.
AIOS_WORKER_CONCURRENCY=4

# Bind address for the API server.
AIOS_API_HOST=127.0.0.1
AIOS_API_PORT=8080

# Logging level.
AIOS_LOG_LEVEL=INFO
